# ─────────────────────────────────────────────────────────────
# BounceBlock.io — Environment variables (Phase 1: Core Foundation)
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. All keys are placeholders below.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Supabase (database + auth) ──
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Stripe (payments) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# Price IDs for the 4 plans (create these in the Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY="price_xxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxx"
STRIPE_PRICE_BUSINESS_MONTHLY="price_xxx"

# ── Verification APIs ──
ZEROBOUNCE_API_KEY="your-zerobounce-key"      # email verification
NUMVERIFY_API_KEY="your-numverify-key"        # phone validation

# ── Email (Zoho Mail SMTP) ──
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="465"
SMTP_USER="hello@bounceblock.io"
SMTP_PASS="your-zoho-app-password"

# Auth is handled by Supabase Auth (uses the Supabase keys above) — no extra vars.

# ── Background queue (optional, for large-list processing at scale) ──
# Until set, full processing runs inline (fine for dev / smaller lists).
QSTASH_URL=""
QSTASH_TOKEN=""

# ── Analytics (optional, privacy-friendly / cookieless) ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
